APP_NAME=Anti-Phishing
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg2://phishguard:phishguard@db:5432/phishguard
REDIS_URL=redis://redis:6379/0
AUTO_MIGRATE=true
MAIL_IMAP_HOST=imap.mail.ru
MAIL_IMAP_PORT=993
MAIL_IMAP_USERNAME=your_mailru_login
MAIL_IMAP_PASSWORD=your_mailru_app_password
MAIL_IMAP_FOLDER=INBOX
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_FEEDBACK_POLL_ENABLED=true
TELEGRAM_FEEDBACK_POLL_INTERVAL_SECONDS=20
TELEGRAM_API_TIMEOUT_SECONDS=15
TELEGRAM_API_RETRIES=2
TELEGRAM_API_RETRY_SLEEP_SECONDS=1.0
TELEGRAM_NOTIFICATION_ASYNC=true
MODEL_PATH=/app/data/models/phishguard_model.joblib
VECTORIZER_PATH=/app/data/models/phishguard_vectorizer.joblib
SCALER_PATH=/app/data/models/phishguard_tabular_scaler.joblib
TEXT_FIELD_LIMIT=30000
POLL_CRON_MINUTES=5
MAIL_POLL_ENABLED=true
MAIL_POLL_INTERVAL_SECONDS=60
MAIL_FETCH_LIMIT=20
MAIL_INITIAL_BOOTSTRAP_LIMIT=5
MAIL_POLL_LOCK_TTL_SECONDS=300
TELEGRAM_POLL_LOCK_TTL_SECONDS=120
NOTIFICATION_TASK_LOCK_TTL_SECONDS=120
NOTIFY_ON_ALL_EMAILS=true
NOTIFY_ONLY_HIGH_RISK=false
TELEGRAM_INCLUDE_FULL_TEXT=true
TELEGRAM_FULL_TEXT_LIMIT=3500
WHITELIST_PATH=/app/data/config/whitelist_emails.txt
DNS_CHECKS_ENABLED=true
DOMAIN_SECURITY_RESOLVERS=1.1.1.1,8.8.8.8
URL_EXPANSION_ENABLED=true
URL_CONTENT_FETCH_ENABLED=true
URL_REQUEST_TIMEOUT_SECONDS=12
URL_REQUEST_CONNECT_TIMEOUT_SECONDS=5
URL_REQUEST_RETRIES=1
URL_REQUEST_RETRY_SLEEP_SECONDS=1.0
URL_MAX_CONTENT_CHARS=18000
URL_DEEP_ANALYSIS_ENABLED=true
URL_MAX_INSPECTED_LINKS_PER_EMAIL=3
URL_MAX_DEEP_FETCH_LINKS_PER_EMAIL=1
